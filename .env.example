# WeStamp — Environment Variables
# Copy this file to .env.local and fill in real values.
# Do NOT commit .env.local to version control.

# Operator access gate passphrase (required for /jobs, /upload/[id], operator APIs)
OPERATOR_PASSPHRASE=

# Storage backend: "local" (default) or "supabase"
STORAGE_BACKEND=local

# Supabase connection (required only when STORAGE_BACKEND=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# PDF generation — Chrome/Chromium executable path (optional)
# Required only if Chrome is not in a standard system location.
# The app auto-detects common paths on macOS, Linux, and Windows.
# Set one of these if auto-detection fails in your deployment environment.
# CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome
# CHROME_PATH=/usr/bin/chromium

# App base URL for PDF generation (optional)
# Used by Puppeteer to construct the print page URL.
# Set this if the app's public URL cannot be reliably derived from request headers
# (e.g. containers, internal networking, non-standard reverse proxy setups).
# If unset, the app falls back to x-forwarded-proto + host headers.
# APP_BASE_URL=https://app.example.com

# STSDS portal probe (dev/local only, not required for production)
# ENABLE_STSDS_PORTAL_PROBE=true
